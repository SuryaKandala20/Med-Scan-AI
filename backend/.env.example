# ═══════════════════════════════════════════════
# MedScan AI — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# NEVER commit .env to git!
# ═══════════════════════════════════════════════

# ── OpenAI API Key ──
# Get yours at: https://platform.openai.com/api-keys
# Pricing: ~$0.01 per chat conversation (GPT-4o-mini) or ~$0.03 (GPT-4o)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI Model ──
# Options: gpt-4o (best, ~$0.01/chat), gpt-4o-mini (cheaper, ~$0.003/chat)
OPENAI_MODEL=gpt-4o-mini

# ── Kaggle API ──
# Get yours at: https://www.kaggle.com/settings → API → Create New Token
# Downloads kaggle.json — put username and key below
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
